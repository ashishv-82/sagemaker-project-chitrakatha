###############################################################################
# Project Chitrakatha — RDS PostgreSQL + pgvector
#
# Why: Replaces FAISS-on-S3 with a persistent, always-on vector store.
#      pgvector enables cosine similarity search directly in PostgreSQL —
#      no separate vector database needed. db.t4g.micro is the smallest
#      available RDS instance; ~$20 AUD/month.
#
# Constraints:
#   - Instance is in private subnets only — never publicly reachable.
#   - Credentials generated by Terraform and stored in Secrets Manager;
#     never hardcoded anywhere.
#   - Schema init (CREATE EXTENSION vector, CREATE TABLE embeddings) runs
#     on first pipeline execution via pgvector_writer.py (idempotent).
###############################################################################

resource "random_password" "rds" {
  length           = 32
  special          = true
  override_special = "!#$%&*()-_=+[]{}<>:?"
}

resource "aws_db_subnet_group" "chitrakatha" {
  name       = "${var.project_name}-db-subnet-group"
  subnet_ids = [aws_subnet.private_a.id, aws_subnet.private_b.id]

  tags = {
    Name       = "${var.project_name}-db-subnet-group"
    Project    = "Chitrakatha"
    CostCenter = "MLOps-Research"
  }
}

resource "aws_db_instance" "chitrakatha" {
  identifier        = "${var.project_name}-pgvector"
  engine            = "postgres"
  engine_version    = "16"
  instance_class    = var.db_instance_class
  allocated_storage = 20
  storage_type      = "gp2"
  storage_encrypted = true
  kms_key_id        = aws_kms_key.chitrakatha.arn

  db_name  = var.db_name
  username = "chitrakatha_admin"
  password = random_password.rds.result

  db_subnet_group_name   = aws_db_subnet_group.chitrakatha.name
  vpc_security_group_ids = [aws_security_group.rds.id]
  publicly_accessible    = false

  backup_retention_period = 7
  skip_final_snapshot     = true
  deletion_protection     = false

  # pgvector extension is enabled via CREATE EXTENSION in application code —
  # no custom parameter group needed for PostgreSQL 16 on RDS.

  tags = {
    Name       = "${var.project_name}-pgvector"
    Project    = "Chitrakatha"
    CostCenter = "MLOps-Research"
  }
}

###############################################################################
# Secrets Manager — RDS credentials
###############################################################################

resource "aws_secretsmanager_secret" "rds_credentials" {
  name                    = "${var.project_name}/rds_credentials"
  recovery_window_in_days = 0 # Immediate deletion allowed in dev

  tags = {
    Project    = "Chitrakatha"
    CostCenter = "MLOps-Research"
  }
}

resource "aws_secretsmanager_secret_version" "rds_credentials" {
  secret_id = aws_secretsmanager_secret.rds_credentials.id
  secret_string = jsonencode({
    host     = aws_db_instance.chitrakatha.address
    port     = aws_db_instance.chitrakatha.port
    dbname   = aws_db_instance.chitrakatha.db_name
    username = aws_db_instance.chitrakatha.username
    password = random_password.rds.result
  })
}
